# brz Configuration
# Copy this to .env and fill in your values.
# Workflow-specific variables (EMAIL, PASSWORD, etc.) are set via --env flags or here.

# Optional: show browser window (useful for CAPTCHAs or debugging)
# BRZ_HEADED=1

# Optional: enable debug logging + failure screenshots
# BRZ_DEBUG=1

# Optional: custom Chrome profile directory
# BRZ_PROFILE_DIR=/path/to/chrome-profile
